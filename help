#!/bin/zsh
#
# help - Display help documents from ~/binshared/helpdocs/
#
# Usage:
#   help                  List all available help topics
#   help <topic>          Display help for <topic> with line numbers
#   help <topic> <line>   Copy line <line> from <topic> to clipboard
#

HELP_DIR="$HOME/binshared/helpdocs/"

# No arguments: list all available help topics
if [[ $# -eq 0 ]]; then
    echo "Help is available for the following:" 
    
    # ${file:t:r} strips directory path (:t) and extension (:r) - zsh syntax
    for file in "$HELP_DIR"/*.md; do
        [[ -e $file ]] || continue  # Skip if no .md files exist
        echo "- ${file:t:r}"
    done

# One argument: display the help file with line numbers
elif [[ $# -eq 1 ]]; then
    with_what="$1.md"
    file_path="$HELP_DIR/$with_what"
    
    if [[ -f "$file_path" ]]; then
        echo ""
        # Print each line with the line number at the front, including blank lines
        awk '{printf "%2d %s\n", NR, $0}' "$file_path"
    else
        echo "Help for file $1 does not exist"
    fi

# Two arguments: copy specific line from help file to clipboard
elif [[ $# -eq 2 ]]; then
    with_what="$1.md"
    line_number="$2"
    file_path="$HELP_DIR/$with_what"
    
    if [[ -f "$file_path" ]]; then
        if [[ "$line_number" =~ ^[0-9]+$ ]]; then
            command=$(sed "${line_number}q;d" "$file_path")
            echo "Copying line $line_number from $1 to clipboard:"
            echo "$command"
            echo "$command" | pbcopy  # Copy the command to the clipboard
        else
            echo "The second parameter must be a number representing the line number."
        fi
    else
        echo "Help for file $1 does not exist"
    fi

else
    echo "Usage: help.sh [optional topic] [optional line number]"
    exit 1
fi