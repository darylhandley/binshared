#!/bin/bash

M2_DIR="$HOME/.m2"
SETTINGS_FILE="$M2_DIR/settings.xml"

# Dynamically discover all settings_*.xml files
settings_files=($(ls "$M2_DIR"/settings_*.xml 2>/dev/null))

# Check if any settings files were found
if [ ${#settings_files[@]} -eq 0 ]; then
    echo "Error: No settings_*.xml files found in $M2_DIR"
    exit 1
fi

# Extract clean names (remove path and settings_ prefix, .xml suffix)
declare -a clean_names
declare -a file_map
for file in "${settings_files[@]}"; do
    basename_file=$(basename "$file")
    clean_name=${basename_file#settings_}
    clean_name=${clean_name%.xml}
    clean_names+=("$clean_name")
    file_map["$clean_name"]="$basename_file"
done

# Accept target as argument, else prompt
if [ $# -eq 0 ]; then
    echo "Choose settings file to swap in:"
    for i in "${!clean_names[@]}"; do
        echo "$((i+1))) ${clean_names[i]}"
    done
    read -p "Enter choice (1-${#clean_names[@]}): " choice

    # Validate numeric input
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt ${#clean_names[@]} ]; then
        echo "Invalid choice"
        exit 1
    fi

    target_clean="${clean_names[$((choice-1))]}"
    target="${file_map[$target_clean]}"
else
    # Check if argument matches any clean name
    target_clean="$1"
    target="${file_map[$target_clean]}"

    if [ -z "$target" ]; then
        echo "Invalid target: $1"
        echo -n "Valid options: "
        printf "%s " "${clean_names[@]}"
        echo
        exit 1
    fi
fi

if [ ! -f "$M2_DIR/$target" ]; then
    echo "Target file $M2_DIR/$target does not exist."
    exit 1
fi

# Backup current settings.xml
cp "$SETTINGS_FILE" "$SETTINGS_FILE.bak"

# Swap in the selected settings file
cp "$M2_DIR/$target" "$SETTINGS_FILE"
echo "Swapped $target into $SETTINGS_FILE. Backup saved as settings.xml.bak."
